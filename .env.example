# ---------------------------------------------------------------------------
# API KEYS — used when *_MODE=api (default)
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=...

# ---------------------------------------------------------------------------
# PER-PROVIDER MODE SWITCH
# "api" (default) hits the SDK. "cli" shells out to the provider's CLI binary.
# CLI mode is LOCAL-DEV ONLY — GitHub runners cannot invoke the Claude/Gemini
# CLIs. The factory refuses cli mode when GITHUB_ACTIONS=true.
# ---------------------------------------------------------------------------
ANTHROPIC_MODE=api        # "api" | "cli"
OPENAI_MODE=api           # "api" only (no local CLI)
GOOGLE_MODE=api           # "api" | "cli"

# Optional CLI binary paths (override if not on PATH)
# CLAUDE_CLI_BIN=/usr/local/bin/claude
# GEMINI_CLI_BIN=/usr/local/bin/gemini

# ---------------------------------------------------------------------------
# GITHUB ACTION — only used by `secure-review pr`
# ---------------------------------------------------------------------------
GITHUB_TOKEN=ghp_...
